{
  "name": "skills-cli",
  "version": "1.0.0",
  "description": "Skills management CLI for development workflows",
  "type": "module",
  "main": "skills-launcher.js",
  "bin": {
    "skills": "./skills-launcher.js"
  },
  "scripts": {
    "start": "node bin/skills.mjs",
