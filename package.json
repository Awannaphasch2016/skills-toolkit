{
  "name": "skills-cli",
  "version": "1.0.0",
  "description": "Skills management CLI for development workflows",
  "type": "module",
  "main": "skills-launcher.js",
  "bin": {
    "skills": "./skills-launcher.js"
  },
  "scripts": {
    "start": "node bin/skills.mjs",
    "skills:list": "node bin/skills.mjs list",
    "skills:add": "node bin/skills.mjs add",
    "skills:install": "node bin/skills.mjs install",
    "skills:search": "node bin/skills.mjs search",
    "skills:validate": "node bin/skills.mjs validate",
    "skills:status": "node bin/skills.mjs status",
    "skills:migrate": "node bin/skills.mjs migrate",
    "skills:analytics": "node bin/skills.mjs analytics",
    "skills:mode": "node bin/skills.mjs mode",
    "test": "node test/test-runner.js",
    "migrate": "node migrate-profiles.js"
  },
  "keywords": [
    "cli",
    "skills",
    "development",
    "tools",
    "npx",
    "skillport",
    "opencli"
  ],
  "author": "Anak",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Awannaphasch2016/skills-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Awannaphasch2016/skills-toolkit/issues"
  },
  "homepage": "https://github.com/Awannaphasch2016/skills-toolkit#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "pg": "^8.20.0"
  }
}
